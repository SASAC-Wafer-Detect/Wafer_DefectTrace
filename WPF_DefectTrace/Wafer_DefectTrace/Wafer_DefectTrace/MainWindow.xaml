<Window x:Class="Wafer_DefectTrace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Wafer_DefectTrace"
        Title="Wafer_DefectTrace — 웨이퍼 불량 패턴 진단 시스템"
        Height="820" Width="1100"
        MinHeight="720" MinWidth="900"
        Background="#1A2332"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 색상 -->
        <SolidColorBrush x:Key="CardBg"       Color="#243447"/>
        <SolidColorBrush x:Key="DarkBg"       Color="#1A2332"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#2E4060"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#2E75B6"/>
        <SolidColorBrush x:Key="MutedText"    Color="#A0B4C8"/>

        <!-- 카드 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="#243447"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="16"/>
            <Setter Property="BorderBrush"     Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- 섹션 라벨 -->
        <Style x:Key="SLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#A0B4C8"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>

        <!-- 기본 버튼 템플릿 -->
        <ControlTemplate x:Key="BtnBase" TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <!-- Primary 버튼 -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#2E75B6"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource BtnBase}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A85C6"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#1E3050"/>
                    <Setter Property="Foreground" Value="#556070"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Danger 버튼 -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#6B2222"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8B2222"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Ghost 버튼 (건너뛰기) -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="#1E3050"/>
            <Setter Property="Foreground"      Value="#A0B4C8"/>
            <Setter Property="BorderBrush"     Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource BtnBase}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A3F60"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 원인 버튼 -->
        <Style x:Key="BtnCause" TargetType="Button">
            <Setter Property="Background"                Value="#1E3050"/>
            <Setter Property="Foreground"                Value="#A0B4C8"/>
            <Setter Property="BorderBrush"               Value="#2E4060"/>
            <Setter Property="BorderThickness"           Value="1"/>
            <Setter Property="Padding"                   Value="12,9"/>
            <Setter Property="Margin"                    Value="0,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#2A3F60"/>
                                <Setter Property="BorderBrush" Value="#2E75B6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="RowBackground"            Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#1E2D40"/>
            <Setter Property="Foreground"               Value="#A0B4C8"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="ColumnHeaderHeight"       Value="34"/>
            <Setter Property="RowHeight"                Value="34"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="SelectionMode"            Value="Single"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#1A2332"/>
            <Setter Property="Foreground"      Value="#A0B4C8"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderBrush"     Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 헤더 -->
            <RowDefinition Height="*"/>
            <!-- 메인 -->
            <RowDefinition Height="200"/>
            <!-- 이력 -->
        </Grid.RowDefinitions>

        <!-- ── 헤더 ──────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="🔬" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Wafer_DefectTrace" Foreground="#FFFFFF"
                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text=" — 웨이퍼 불량 패턴 진단 시스템"
                       Foreground="#A0B4C8" FontSize="13" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── 메인 (좌/우) ──────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── 좌측 패널 ─────────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <!-- 폴더 선택 -->
                    <TextBlock Text="폴더 선택" Style="{StaticResource SLabel}"/>
                    <Button Content="📁  폴더 선택"
                            Style="{StaticResource BtnPrimary}"
                            Command="{Binding SelectFolderCommand}"
                            Margin="0,0,0,8"/>
                    <Button Content="🗑  초기화"
                            Style="{StaticResource BtnDanger}"
                            Command="{Binding ResetCommand}"
                            Margin="0,0,0,14"/>

                    <!-- 진행 상황 -->
                    <TextBlock Text="진행 상황" Style="{StaticResource SLabel}"/>
                    <Border Background="#1A2332" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                        <StackPanel>
                            <!-- 진행률 텍스트 -->
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="전체 진행률" Foreground="#A0B4C8" FontSize="11"/>
                                <TextBlock Text="{Binding ProgressText}"
                                           Foreground="#FFFFFF" FontSize="11"
                                           FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                            <!-- 프로그레스 바 -->
                            <Border Background="#2E4060" CornerRadius="3" Height="6" Margin="0,0,0,10">
                                <Border Background="#2E75B6" CornerRadius="3"
                                        HorizontalAlignment="Left"
                                        Width="{Binding ProgressBarWidth}"/>
                            </Border>
                            <!-- 통계 4개 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#243447" CornerRadius="6" Padding="6" Margin="0,0,4,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding TotalCount}"
                                                   Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="전체" Foreground="#A0B4C8" FontSize="10"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#243447" CornerRadius="6" Padding="6" Margin="2,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding NoneSkippedCount}"
                                                   Foreground="#556070" FontSize="15" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="None" Foreground="#A0B4C8" FontSize="10"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="#243447" CornerRadius="6" Padding="6" Margin="2,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding DefectCount}"
                                                   Foreground="#E24B4A" FontSize="15" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="불량 감지" Foreground="#A0B4C8" FontSize="10"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Background="#243447" CornerRadius="6" Padding="6" Margin="4,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SavedCount}"
                                                   Foreground="#1D9E75" FontSize="15" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="저장 완료" Foreground="#A0B4C8" FontSize="10"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 현재 이미지 미리보기 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="현재 이미지"
                                   Foreground="#A0B4C8" FontSize="10" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CurrentFileName}"
                                   Foreground="#FFFFFF" FontSize="10"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   Visibility="{Binding ImageVisibility}"/>
                    </Grid>
                    <Border Background="#1A2332" CornerRadius="8" Height="180"
                            Margin="0,0,0,6">
                        <Grid>
                            <!-- 이미지 — ViewModel 의 PreviewImage 바인딩 -->
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform" Margin="8"
                                   Visibility="{Binding ImageVisibility}"/>
                            <!-- 대기 안내 -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding NoImageVisibility}">
                                <TextBlock Text="폴더를 선택하면" Foreground="#556070"
                                           FontSize="12" HorizontalAlignment="Center"/>
                                <TextBlock Text="자동으로 시작됩니다" Foreground="#556070"
                                           FontSize="12" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── 우측 패널 ─────────────────────────── -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 대기 안내 -->
                    <StackPanel Grid.Row="0" Grid.RowSpan="3"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding WaitingVisibility}">
                        <TextBlock Text="🔍" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="폴더를 선택하면 자동으로 진단을 시작합니다"
                                   Foreground="#A0B4C8" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>

                    <!-- 완료 안내 -->
                    <StackPanel Grid.Row="0" Grid.RowSpan="3"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding DoneVisibility}">
                        <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="모든 이미지 처리 완료"
                                   Foreground="#1D9E75" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding DoneSummaryText}"
                                   Foreground="#A0B4C8" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- 진단 결과 -->
                    <StackPanel Grid.Row="0" Visibility="{Binding ResultVisibility}">
                        <TextBlock Text="진단 결과" Style="{StaticResource SLabel}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="패턴명" Foreground="#A0B4C8" FontSize="10"/>
                                <TextBlock Text="{Binding PatternName}"
                                           Foreground="#FFFFFF" FontSize="24" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="신뢰도" Foreground="#A0B4C8" FontSize="10"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding Confidence}"
                                           Foreground="#2E75B6" FontSize="24" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>

                        <!-- 심각도 배지 -->
                        <Border CornerRadius="4" Padding="10,5"
                                Background="{Binding SeverityColor}"
                                HorizontalAlignment="Left" Margin="0,0,0,14">
                            <TextBlock Text="{Binding SeverityText}"
                                       Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                        <Separator Background="#2E4060" Margin="0,0,0,14"/>
                    </StackPanel>

                    <!-- 원인 버튼 목록 -->
                    <ScrollViewer Grid.Row="1" Visibility="{Binding ResultVisibility}"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="공정 원인 선택" Style="{StaticResource SLabel}"/>
                            <ItemsControl ItemsSource="{Binding CauseOptions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Tag="{Binding}"
                                                Command="{Binding DataContext.CauseSelectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource BtnCause}">
                                            <TextBlock Text="{Binding DisplayLabel}"
                                                       Foreground="{Binding TextColor}"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 저장 / 건너뛰기 버튼 -->
                    <Grid Grid.Row="2" Margin="0,12,0,0"
                          Visibility="{Binding ResultVisibility}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="💾  저장 후 다음으로"
                                Style="{StaticResource BtnPrimary}"
                                IsEnabled="{Binding CanSave}"
                                Command="{Binding SaveCommand}"/>
                        <Button Grid.Column="2"
                                Content="건너뛰기"
                                Style="{StaticResource BtnGhost}"
                                Command="{Binding SkipCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ── 하단: 동일 패턴 이력 ─────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 이력 헤더 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <TextBlock Text="동일 패턴 이전 진단 이력"
                               Style="{StaticResource SLabel}" Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                    <Border Background="#1A3D6B" CornerRadius="4" Padding="8,2"
                            Visibility="{Binding HistoryBadgeVisibility}">
                        <TextBlock Text="{Binding HistoryBadgeText}"
                                   Foreground="#2E75B6" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- 이력 테이블 -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredHistory}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="진단 시간"   Binding="{Binding Time}"         Width="150"/>
                        <DataGridTextColumn Header="패턴"        Binding="{Binding Pattern}"      Width="100"/>
                        <DataGridTextColumn Header="신뢰도"      Binding="{Binding Confidence}"   Width="80"/>
                        <DataGridTextColumn Header="선택한 원인" Binding="{Binding SelectedCause}" Width="*"/>
                        <DataGridTextColumn Header="파일명"      Binding="{Binding FileName}"     Width="300"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 이력 없을 때 -->
                <TextBlock Grid.Row="1"
                           Text="저장된 이력이 없습니다"
                           Foreground="#556070" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding NoHistoryVisibility}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
